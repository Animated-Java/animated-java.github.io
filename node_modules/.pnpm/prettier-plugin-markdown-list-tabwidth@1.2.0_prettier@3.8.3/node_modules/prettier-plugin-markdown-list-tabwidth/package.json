{
    "name": "prettier-plugin-markdown-list-tabwidth",
    "version": "1.2.0",
    "description": "A Prettier plugin that reverts the change in Prettier v3.4.0 that altered how Markdown list items are indented.",
    "keywords": [
        "prettier",
        "plugin",
        "markdown",
        "mdx",
        "remark",
        "list",
        "tabwidth",
        "3.3.3",
        "3.4.0",
        "revert",
        "rollback",
        "parser",
        "printer"
    ],
    "homepage": "https://github.com/8Crafter-Studios/prettier-plugin-markdown-list-tabwidth#readme",
    "bugs": {
        "email": "8crafteryt@gmail.com",
        "url": "https://github.com/8Crafter-Studios/prettier-plugin-markdown-list-tabwidth/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/8Crafter-Studios/prettier-plugin-markdown-list-tabwidth.git"
    },
    "license": "MIT",
    "author": {
        "email": "8crafteryt@gmail.com",
        "name": "8Crafter",
        "url": "https://www.8crafter.com"
    },
    "type": "module",
    "main": "./index.mjs",
    "module": "./index.mjs",
    "exports": {
        ".": "./index.mjs",
        "./full-replace": "./index-full-replace.mjs",
        "./packge.json": "./package.json",
        "./*": "./*.mjs",
        "./*.js": "./*.mjs",
        "./*.mjs": "./*.mjs"
    },
    "peerDependencies": {
        "prettier": "*"
    },
    "devDependencies": {
        "@types/node": "14.0.0",
        "eslint": "^9.39.2",
        "eslint-plugin-import": "^2.32.0",
        "prettier": "^3.7.4",
        "typescript-eslint": "^8.52.0"
    },
    "engines": {
        "node": ">=14"
    },
    "scripts": {
        "addGitTagToCommit": "node -e \"import { exec } from 'node:child_process'; import { stderr } from 'node:process'; for (const command of ['git tag v' + process.env.npm_package_version, 'git push --tags']) await new Promise((resolve, reject) => ((childProcess) => (childProcess.stdout.pipe(process.stdout), childProcess.stderr.pipe(stderr)))((console.log('> ' + command), exec(command, (error) => (error ? reject(error) : resolve())))));\"",
        "addGitTagToCommit:bash": "git tag v$npm_package_version && git push --tags",
        "addGitTagToCommit:cmd": "git tag v%npm_package_version% && git push --tags"
    }
}
