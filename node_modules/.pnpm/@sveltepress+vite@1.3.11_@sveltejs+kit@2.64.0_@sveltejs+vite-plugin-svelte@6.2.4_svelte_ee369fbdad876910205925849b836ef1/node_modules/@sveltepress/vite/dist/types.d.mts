import { BundledLanguage } from 'shiki/langs';
import { Plugin } from 'unified';
import { PluginOption } from 'vite';

type RemarkLiveCode = Plugin<[], any>;
type Highlighter = (code: string, lang: BundledLanguage, meta?: string) => string | Promise<string>;
type ThemeVitePlugins = PluginOption[] | ((corePlugin: PluginOption) => Promise<PluginOption[]>) | ((corePlugin: PluginOption) => PluginOption[]);
interface SiteConfig {
    title?: string;
    description?: string;
}
interface ResolvedTheme {
    name: string;
    globalLayout: string;
    pageLayout: string;
    vitePlugins: ThemeVitePlugins;
    highlighter: Highlighter;
    remarkPlugins?: Plugin[];
    rehypePlugins?: Plugin[];
    /**
     * The footnote label used for [remark rehype](https://github.com/remarkjs/remark-rehype#api)
     */
    footnoteLabel?: string;
}
type RemarkPluginsOrderer = ((themeRemarkPlugins: Plugin[]) => Plugin[]);
type RehypePluginsOrderer = ((themeRehypePlugins: Plugin[]) => Plugin[]);
interface PageInfo {
    title: string;
    routePath: string;
    content: string;
    frontmatter: Record<string, unknown>;
}
interface LlmsConfig {
    enabled?: boolean;
    title?: string;
    description?: string;
    baseUrl?: string;
    routesDir?: string;
    filter?: (filePath: string, frontmatter: Record<string, unknown>) => boolean;
    sort?: (a: PageInfo, b: PageInfo) => number;
}
interface SveltepressVitePluginOptions {
    theme?: ResolvedTheme;
    siteConfig?: SiteConfig;
    addInspect?: boolean;
    remarkPlugins?: Plugin[] | RemarkPluginsOrderer;
    rehypePlugins?: Plugin[] | RehypePluginsOrderer;
    llms?: LlmsConfig;
}
type LoadTheme<ThemeOptions = any> = (themeOptions?: ThemeOptions) => ResolvedTheme;
type RawRemarkPlugin = Plugin<any[], any> | [Plugin<any[], any>, any];
type AcceptableRemarkPlugin = Array<RawRemarkPlugin>;

export type { AcceptableRemarkPlugin, Highlighter, LlmsConfig, LoadTheme, PageInfo, RawRemarkPlugin, RehypePluginsOrderer, RemarkLiveCode, RemarkPluginsOrderer, ResolvedTheme, SiteConfig, SveltepressVitePluginOptions, ThemeVitePlugins };
